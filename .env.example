# ═══════════════════════════════════════════════════════════════════════
#  Sport Data Solution v3.1.0 — Variables d'environnement
#  USAGE : cp .env.example .env puis éditez les valeurs
# ═══════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_DB=sds_poc
POSTGRES_USER=sds
POSTGRES_PASSWORD=change_me_before_running

# URL pour SQLAlchemy (Python) — host localhost en local
DATABASE_URL=postgresql+psycopg://sds:change_me_before_running@localhost:5432/sds_poc

# ─── pgAdmin (http://localhost:5050) ───────────────────────────────────
PGADMIN_EMAIL=admin@sds.local
PGADMIN_PASSWORD=admin

# ─── Kestra — orchestrateur (http://localhost:8089) ────────────────────
# Les tâches Kestra tournent DANS le réseau Docker sds_network.
# Elles utilisent donc le hostname "postgres" (nom du service), PAS "localhost".
KESTRA_DATABASE_URL=postgresql+psycopg://sds:change_me_before_running@postgres:5432/sds_poc
KESTRA_DATABASE_URL_JDBC=jdbc:postgresql://postgres:5432/sds_poc

# Chemin absolu du projet sur votre machine hôte
PROJECT_PATH=/absolute/path/to/sds_v3

# ─── API Google Maps (géocodage primaire) ──────────────────────────────
# Si vide, le pipeline bascule automatiquement sur Nominatim (OSM gratuit)
GOOGLE_MAPS_API_KEY=

# ─── Slack (notifications activités) ───────────────────────────────────
# Si vide, les messages sont simulés dans les logs
SLACK_WEBHOOK_URL=

# Webhook dédié aux alertes (optionnel) — laisse vide si inutilisé
SLACK_ALERTS_WEBHOOK_URL=

# ─── Pipeline ──────────────────────────────────────────────────────────
PIPELINE_VERSION=3.1.0
DQ_THRESHOLD=80
LOG_LEVEL=INFO
